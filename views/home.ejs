<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Main Page</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
    <h1>Telegram Post</h1>
    <% for(post of posts){ %>
        <div class="post-box">
            <h3 class="username">@<%= post.username %></h3>
            <p class="ideas"><%= post.ideas %></p>
            <div class="links">
            <a href="http://localhost:8080/posts/<%= post.id %>">See Details</a>
            <a href="http://localhost:8080/posts/<%= post.id %>/edit" class="edit-style">Edit Your Ideas</a>
            <form action="/posts/<%= post.id %>?_method=delete" method="post">
                <button class="delete-btn">Delete</button>
            </form>
            </div>
        </div>
    <% } %>
    <a href="http://localhost:8080/posts/new">Add post here</a>
    </div>
</body>
</html>